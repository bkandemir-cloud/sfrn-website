---
const nav = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/get-involved/', label: 'Get Involved' },
  { href: '/news/', label: 'News' },
  { href: '/contact/', label: 'Contact' },
];
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Sixth Form Research Network home">
      <img src="/images/sfrn-mark.png" alt="" width="44" height="44" />
      <span>Sixth Form<br />Research Network</span>
    </a>
    <button class="menu-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
    <nav id="site-nav" aria-label="Main navigation">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a
            class="btn btn-primary nav-cta"
            href="https://forms.cloud.microsoft/e/HfXTmbGfTH"
            target="_blank"
            rel="noopener"
          >Register for the webinar</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 250, 247, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.8rem;
    padding-bottom: 0.8rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--navy);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.82rem;
    line-height: 1.15;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  nav ul {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a:not(.btn) {
    color: var(--navy);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.98rem;
    padding: 0.3rem 0;
    border-bottom: 2px solid transparent;
    transition: border-color 0.25s var(--ease);
  }
  nav a:not(.btn):hover,
  nav a[aria-current='page']:not(.btn) {
    border-bottom-color: var(--teal);
  }
  .nav-cta { padding: 0.55rem 1.2rem; font-size: 0.92rem; }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
  }
  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2.5px;
    background: var(--navy);
    border-radius: 2px;
    transition: transform 0.3s var(--ease), opacity 0.3s var(--ease);
  }

  @media (max-width: 860px) {
    .menu-toggle { display: flex; }
    nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 20px 40px rgba(4, 6, 64, 0.1);
    }
    nav.open { display: block; }
    nav ul {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: 0.8rem 1.4rem 1.4rem;
    }
    nav li { width: 100%; }
    nav a:not(.btn) {
      display: block;
      padding: 0.8rem 0;
      font-size: 1.05rem;
    }
    .nav-cta { margin-top: 0.8rem; display: inline-block; }
  }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!!open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
