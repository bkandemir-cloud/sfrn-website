---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Journal | Sixth Form Research Network"
  description="The Network intends to launch a journal dedicated to Sixth Form student research. Launching in 2027."
>
  <section class="section page-head">
    <div class="container">
      <span class="kicker">Journal</span>
      <h1>A journal for Sixth Form research</h1>
      <p class="lead">
        Sixth Form students deserve real publishing opportunities; the Network intends to
        launch a journal dedicated to Sixth Form student research.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="coming-soon">
        <img src="/images/sfrn-mark.png" alt="" width="120" height="120" loading="lazy" />
        <span class="badge">Launching in 2027</span>
        <h2>The first issue arrives in 2027</h2>
        <p>
          We&rsquo;re preparing the journal now, ready to launch in 2027. It will be free to
          read online, right here on this page.
        </p>
        <p>
          Want your work considered for a future issue, or to hear when the first one is out?
          Join the introductory webinar or follow us on LinkedIn.
        </p>
        <div class="actions">
          <a class="btn btn-primary" href="https://forms.cloud.microsoft/e/HfXTmbGfTH" target="_blank" rel="noopener">
            Register for the webinar
          </a>
          <a class="btn btn-secondary" href="https://www.linkedin.com/company/sixthformresearchnetwork" target="_blank" rel="noopener">
            Follow on LinkedIn
          </a>
        </div>
      </div>

      <!--
        ISSUU embed goes here when the first issue is published.
        Replace the .coming-soon block above with the responsive embed below,
        swapping in the real ISSUU document URL:

        <div class="issuu-embed">
          <iframe
            src="https://e.issuu.com/embed.html?d=DOCUMENT_ID&u=USERNAME"
            title="SFRN Journal"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>

        Matching CSS (add to the style block):
        .issuu-embed { position: relative; width: 100%; aspect-ratio: 4 / 3; }
        .issuu-embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; border-radius: var(--radius); }
      -->
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { padding-bottom: 0; }
  .page-head .lead { max-width: 44rem; }

  .coming-soon {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(2.5rem, 6vw, 4.5rem) 2rem;
    text-align: center;
    max-width: 44rem;
    margin: 0 auto;
  }
  .coming-soon img {
    opacity: 0.9;
    margin-bottom: 1.2rem;
  }
  .badge {
    display: inline-block;
    background: var(--teal-tint);
    color: var(--teal);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    margin-bottom: 1.4rem;
  }
  .coming-soon h2 { margin-bottom: 0.6rem; }
  .coming-soon p {
    color: var(--muted);
    max-width: 34rem;
    margin-left: auto;
    margin-right: auto;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.8rem;
  }
</style>
